# ── PayPal ──
PAYPAL_CLIENT_ID=your_client_id
PAYPAL_CLIENT_SECRET=your_secret
PAYPAL_PLAN_ID=P-xxxxxxxx
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your_webhook_id

# License signing (openssl rand -hex 32)
LICENSE_SECRET=change_me

# ── Resend (https://resend.com/api-keys) ──
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=BigTextDisplay <hello@bigtextdisplay.com>
SITE_URL=https://www.bigtextdisplay.com

# Optional: protect cron endpoint
CRON_SECRET=random_secret

# ── Vercel frontend (build-time) ──
VITE_PAYPAL_CLIENT_ID=your_client_id
VITE_PAYPAL_PLAN_ID=P-xxxxxxxx
VITE_SITE_URL=https://www.bigtextdisplay.com

# Upstash Redis — auto-injected via Vercel Storage
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Local dev
PORT=8787
NODE_ENV=development