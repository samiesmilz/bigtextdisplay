# ── PayPal (https://developer.paypal.com/dashboard/applications) ──
PAYPAL_CLIENT_ID=your_sandbox_or_live_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret
PAYPAL_WEBHOOK_ID=your_webhook_id
PAYPAL_PLAN_ID=P-xxxxxxxxxxxxxxxx
PAYPAL_MODE=sandbox

# License signing — generate: openssl rand -hex 32
# Set in Vercel → Settings → Environment Variables (all environments)
LICENSE_SECRET=change_me_to_random_64_char_hex

# ── Vercel frontend (build-time env vars) ──
VITE_PAYPAL_CLIENT_ID=your_sandbox_or_live_client_id
VITE_PAYPAL_PLAN_ID=P-xxxxxxxxxxxxxxxx
VITE_SITE_URL=https://bigtextdisplay.com

# ── Phone remote storage (required on Vercel for Pro remote) ──
# Vercel Dashboard → Storage → Upstash Redis → Connect to project
# Vercel auto-injects KV_REST_API_URL + KV_REST_API_TOKEN
# Or paste Upstash credentials manually:
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token

# ── Local dev only ──
PORT=8787
NODE_ENV=development